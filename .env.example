# ============================================================
# Agricultural Risk Assessment Platform - Environment Config
# Copy to .env and fill in your values
# ============================================================

# Application
APP_NAME="GEoN Risk Assessment Platform"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=true
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
API_V1_PREFIX="/api/v1"

# Server
HOST="0.0.0.0"
PORT=8000
WORKERS=4

# Database
DATABASE_URL="postgresql+asyncpg://agri_user:agri_pass@localhost:5432/agri_risk_db"
DATABASE_URL_SYNC="postgresql://agri_user:agri_pass@localhost:5432/agri_risk_db"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=3600
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# JWT
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting (requests per day)
FREE_TIER_DAILY_LIMIT=10
MEDIUM_TIER_DAILY_LIMIT=100
PREMIUM_TIER_DAILY_LIMIT=10000

# ML Models
MODEL_STORE_PATH="./ml_models"
MODEL_RETRAIN_INTERVAL_DAYS=30

# Reports
REPORT_STORAGE_PATH="./reports/generated"
REPORT_RETENTION_DAYS=90

# Monitoring
PROMETHEUS_ENABLED=true
SENTRY_DSN=""

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"
